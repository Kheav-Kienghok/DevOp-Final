[jenkins]
jenkins ansible_host=${jenkins_host} ansible_user=${ssh_user} ansible_ssh_common_args='-o StrictHostKeyChecking=no'

[sonarqube]
sonarqube ansible_host=${sonarqube_host} ansible_user=${ssh_user} ansible_ssh_common_args='-o StrictHostKeyChecking=no'

[all:vars]
ansible_python_interpreter=/usr/bin/python3